{
  "name": "miya-applet",
  "version": "1.0.0",
  "description": "MiyaShop 移动端 App — iOS & Android",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "cap:init": "npx cap init miya-applet com.miyashop.app --web-dir=dist",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:build:ios": "npm run build && npx cap copy && npx cap sync",
    "cap:build:android": "npm run build && npx cap copy && npx cap sync",
    "cap:update": "npx cap update"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/camera": "^6.0.1",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.1",
    "@capacitor/share": "^6.0.1",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "axios": "^1.6.7",
    "vant": "^4.8.11",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-auto-import": "^0.17.5",
    "postcss-pxtorem": "^6.1.0"
  }
}
